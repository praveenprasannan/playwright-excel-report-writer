{
  "compilerOptions": {
    "target": "es2025",
    "module": "esnext",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",

    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": ["src"]
}
