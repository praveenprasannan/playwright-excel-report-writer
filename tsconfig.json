{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",

    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["src"]
}
